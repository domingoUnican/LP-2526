Rule 57    let_list -> let_item
Rule 58    let_item -> OBJECTID : TYPEID optional_assign
Rule 59    optional_assign -> <empty>
Rule 60    optional_assign -> ASSIGN expresion  [precedence=right, level=1]
Rule 61    rama_list -> error ;
